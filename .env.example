# StoryPal Environment Variables
# Copy this file to .env and fill in your real keys
# cp .env.example .env

# OpenAI — Required for story + image generation
OPENAI_API_KEY=sk-xxxx
EXPO_PUBLIC_OPENAI_API_KEY=sk-xxxx

# ElevenLabs — Optional, falls back to expo-speech if missing
ELEVENLABS_API_KEY=sk_xxxx
EXPO_PUBLIC_ELEVENLABS_API_KEY=sk_xxxx

# RevenueCat — Optional, not needed for V1 (free launch)
REVENUECAT_API_KEY=test_xxxx

# Supabase — Required for auth, storage, database
SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxx
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
